<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>왕게임</title>

<style>
* { box-sizing: border-box; }

body {
  margin: 0;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: #f6f7f9;
  color: #222;
}

.container {
  max-width: 480px;
  margin: auto;
  padding: 16px;
}

h1 {
  text-align: center;
  margin-bottom: 12px;
}

textarea {
  width: 100%;
  min-height: 100px;
  padding: 12px;
  border-radius: 10px;
  border: 1px solid #ddd;
  font-size: 16px; /* 모바일 확대 방지 */
  resize: vertical;
}

.buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 12px;
}

button {
  padding: 14px;
  border-radius: 10px;
  border: none;
  font-size: 15px;
  cursor: pointer;
  background: #e9ebef;
}

button.primary {
  background: #ff5a5f;
  color: white;
  font-weight: bold;
}

button.secondary {
  background: #4c6ef5;
  color: white;
}

.card {
  background: white;
  border-radius: 14px;
  padding: 14px;
  margin-top: 16px;
}

.king {
  font-size: 18px;
  font-weight: bold;
  color: #ff5a5f;
  text-align: center;
  margin-bottom: 10px;
}

ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

li {
  padding: 8px 0;
  border-bottom: 1px solid #eee;
  display: flex;
  justify-content: space-between;
}

li:last-child {
  border-bottom: none;
}

.history li {
  font-size: 14px;
  color: #666;
}

.footer-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 6px;
  margin-top: 10px;
}

@media (max-width: 360px) {
  button {
    font-size: 13px;
    padding: 10px;
  }
}
</style>
</head>

<body>

<div class="container">

<h1>👑 왕게임</h1>

<textarea id="players" placeholder="참가자 이름을 한 줄에 한 명씩 입력"></textarea>

<div class="buttons">
  <button class="primary" id="btnRandom">랜덤 왕</button>
  <button class="secondary" id="btnTurn">순차 왕</button>
</div>

<div class="buttons">
  <button id="btnExcept">왕 제외 섞기</button>
  <button id="btnAll">전원 섞기</button>
</div>

<div class="buttons">
  <button id="btnCopy">결과 복사</button>
  <button id="btnReset">기록 초기화</button>
</div>

<div class="card" id="result"></div>

<div class="card">
  <h3>📜 왕 기록</h3>
  <ul id="history" class="history"></ul>
</div>

</div>

<script>
let players = [];
let kingIndex = null;
let lastKing = null;
let turnIndex = 0;
let numbers = [];

function getPlayers() {
  players = document.getElementById("players").value
    .split("\n")
    .map(v => v.trim())
    .filter(v => v);
  if (players.length < 2) {
    alert("최소 2명 이상 필요해!");
    return false;
  }
  return true;
}

function shuffle(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
}

function assignNumbers(exceptKing = false) {
  numbers = [...Array(players.length).keys()].map(n => n + 1);
  if (exceptKing && kingIndex !== null) {
    const keep = numbers[kingIndex];
    numbers.splice(kingIndex, 1);
    shuffle(numbers);
    numbers.splice(kingIndex, 0, keep);
  } else {
    shuffle(numbers);
  }
}

function startRandomKing() {
  if (!getPlayers()) return;
  let candidates = players.map((_, i) => i);
  if (lastKing !== null && players.length > 1) {
    candidates = candidates.filter(i => i !== lastKing);
  }
  kingIndex = candidates[Math.floor(Math.random() * candidates.length)];
  lastKing = kingIndex;
  saveHistory(players[kingIndex]);
  assignNumbers();
  render();
}

function startTurnKing() {
  if (!getPlayers()) return;
  kingIndex = turnIndex % players.length;
  turnIndex++;
  lastKing = kingIndex;
  saveHistory(players[kingIndex]);
  assignNumbers();
  render();
}

function reshuffleExceptKing() {
  if (kingIndex === null) return;
  assignNumbers(true);
  render();
}

function reshuffleAll() {
  if (kingIndex === null) return;
  assignNumbers(false);
  render();
}

function render() {
  let html = `<div class="king">👑 왕: ${players[kingIndex]}</div><ul>`;
  players.forEach((p, i) => {
    html += `<li><span>${p}</span><span>${numbers[i]}</span></li>`;
  });
  html += `</ul>`;
  document.getElementById("result").innerHTML = html;
}

function copyResult() {
  if (kingIndex === null) return;

  let text = `👑 왕: ${players[kingIndex]}\n`;
  players.forEach((p, i) => {
    text += `${p} : ${numbers[i]}\n`;
  });

  const textarea = document.createElement("textarea");
  textarea.value = text;
  document.body.appendChild(textarea);
  textarea.select();
  document.execCommand("copy");
  document.body.removeChild(textarea);

  alert("복사 완료!");
}

function saveHistory(name) {
  const history = JSON.parse(localStorage.getItem("kingHistory") || "[]");
  history.push(name);
  localStorage.setItem("kingHistory", JSON.stringify(history));
  renderHistory();
}

function renderHistory() {
  const history = JSON.parse(localStorage.getItem("kingHistory") || "[]");
  const ul = document.getElementById("history");
  ul.innerHTML = "";
  history.forEach((n, i) => {
    ul.innerHTML += `<li>${i + 1}회차 · ${n}</li>`;
  });
}

function resetHistory() {
  localStorage.removeItem("kingHistory");
  renderHistory();
}

// 이벤트 연결 (모바일 안정성)
document.getElementById("btnRandom").addEventListener("click", startRandomKing);
document.getElementById("btnTurn").addEventListener("click", startTurnKing);
document.getElementById("btnExcept").addEventListener("click", reshuffleExceptKing);
document.getElementById("btnAll").addEventListener("click", reshuffleAll);
document.getElementById("btnCopy").addEventListener("click", copyResult);
document.getElementById("btnReset").addEventListener("click", resetHistory);

// 터치 반응 개선
document.querySelectorAll("button").forEach(btn => {
  btn.addEventListener("touchstart", () => {});
});

renderHistory();
</script>

</body>
</html>
